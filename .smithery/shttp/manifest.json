              "company_name": {
                "type": "string"
              },
              "company_domain": {
                "type": "string"
              },
              "source": {
                "default": "api",
                "type": "string",
                "enum": [
                  "website_form",
                  "landing_page",
                  "api",
                  "csv_import",
                  "manual",
                  "webhook"
